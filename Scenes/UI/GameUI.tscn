; GameUI — Mobile HUD
; Layout:
;   Top     -> StatsBar (Gold/Geld/Metall/Kristalle/Level/EnergyBar) + 7-slot Hotbar
;   Bot-L   -> D-Pad (4x TextureButton in a cross)
;   Bot-R   -> Action buttons (Jump / Attack / Block)

[node name="GameUI" type="CanvasLayer"]
layer = 10
script = ExtResource("1_ctrl")

[node name="RootControl" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

; TOP AREA — Stats + Hotbar

