; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the properties are not clearly documented.
; Format: key=value pairs, one per line.
; Visit https://docs.godotengine.org/ for documentation.

[configuration]

config_version=5

[application]

config/name="Prime Force"
config/features=PackedStringArray("4.3", "C#", "Mobile")
config/icon="res://Assets/Textures/icon.png"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Prime_Force"

[input]

move_up={
"deadzone": 0.5,
"events": []
}
move_down={
"deadzone": 0.5,
"events": []
}
move_left={
"deadzone": 0.5,
"events": []
}
move_right={
"deadzone": 0.5,
"events": []
}
jump={
"deadzone": 0.5,
"events": []
}
attack={
"deadzone": 0.5,
"events": []
}
block={
"deadzone": 0.5,
"events": []
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
